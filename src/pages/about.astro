---
import Layout from '../layouts/Layout.astro';
const timeline = [
  { year: '2008', text: '留学中、ボストン市内の制作会社にてインターンとして参加。' },
  { year: '2009', text: '株式会社サイブリッジに入社。Webデザイナーとして各種Web制作に従事。' },
  { year: '2011', text: '個人事業主（フリーランス）として活動開始。Web制作・運用支援を行う。株式会社ウィグラに転職。Webデザイナー／コンサルタントとして従事。' },
  { year: '2012', text: 'グランリッジにてWebデザイナー、のちチーフディレクターとして勤務。上級ウェブ解析士を取得し、分析を軸としたWeb制作に取り組む。' },
  { year: '2017', text: '一般社団法人女性起業家スプラウトにて、上級ウェブ解析士として登壇。' },
  { year: '2018', text: 'フリーランスとして再始動。SEO・Webマーケティング支援を継続。WordCamp Tokyo Contributor Day に参加。' },
  { year: '2023', text: '合同会社原田を設立。不動産管理業務に携わる。' },
];
---
<Layout title="About — ZiPZAP" description="ZiPZAPのプロフィール・経歴。Webディレクター原田幾未のキャリアをご紹介します。">
  <div class="container page-wrap">
    <header class="page-header">
      <p class="section-label">About</p>
      <h1 class="page-title">原田 幾未<span class="page-title-en">Ikumi Harada</span></h1>
    </header>

    <div class="about-grid">
      <div class="about-intro">
        <div class="intro-card">
          <div class="intro-avatar">IH</div>
          <div class="intro-meta">
            <h2 class="intro-name">原田 幾未</h2>
            <p class="intro-role">Webディレクター / Web担当（制作〜運用改善）</p>
            <p class="intro-handle">
              <span class="tag">WordPress</span>
              <span class="tag tag--accent">ZiPZAP</span>
            </p>
          </div>
        </div>

        <p class="intro-body">
          リニューアルや運用改善の文脈で、構成設計から制作、公開後の改善支援までを通して関わってきました。特定領域に特化したスペシャリストというよりは、状況に応じて柔軟に動くジェネラリストタイプです。
        </p>
        <p class="intro-body">
          「事業全体の成果を見据えた視点で、ウェブの専門性を活かしていくこと」を大切にしています。制作〜マーケティングに至るまで、事業のデリバリー全体を見ながら価値提供していきたいと考えています。
        </p>

        <!-- Community -->
        <div class="community-block">
          <h3 class="community-title">コミュニティ・継続的な学習</h3>
          <ul class="community-list">
            <li>2018年より WordCamp Tokyo Contributor Day に参加</li>
            <li>二子玉川・八王子 WPmeetup などの勉強会に継続的に参加</li>
            <li>上級ウェブ解析士（WAC11210181）取得</li>
            <li>セミナー講師経験あり（女性起業家向け WordPress ワークショップ）</li>
          </ul>
        </div>
      </div>

      <!-- Timeline -->
      <div class="timeline">
        <h2 class="timeline-title">経歴</h2>
        <div class="timeline-list">
          {timeline.map((item, i) => (
            <div class="tl-item">
              <div class="tl-year">{item.year}</div>
              <div class="tl-dot"></div>
              <div class="tl-body">{item.text}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
.page-wrap { padding: 64px 0 96px; }
.page-header { margin-bottom: 48px; }
.page-title {
  font-size: 40px;
  font-weight: 500;
  margin-top: 8px;
  letter-spacing: -.02em;
  display: flex;
  align-items: baseline;
  gap: 16px;
}
.page-title-en { font-size: 18px; font-weight: 300; color: var(--c-ink-60); }

.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}

/* Intro */
.intro-card {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 24px;
}
.intro-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--c-teal);
  color: var(--c-white);
  font-size: 18px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.intro-name { font-size: 20px; font-weight: 500; }
.intro-role { font-size: 13px; color: var(--c-teal); margin: 4px 0 8px; font-family: var(--font-mono); }
.intro-handle { display: flex; gap: 6px; flex-wrap: wrap; }
.intro-body { font-size: 15px; color: var(--c-ink-60); line-height: 1.8; margin-bottom: 16px; }

.community-block {
  background: var(--c-teal-lt);
  border-radius: var(--radius-md);
  padding: 20px 24px;
  margin-top: 8px;
}
.community-title { font-size: 14px; font-weight: 500; color: var(--c-teal-dk); margin-bottom: 12px; }
.community-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.community-list li {
  font-size: 13px;
  color: var(--c-ink);
  padding-left: 16px;
  position: relative;
  line-height: 1.55;
}
.community-list li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--c-teal);
  font-weight: 500;
}

/* Timeline */
.timeline-title { font-size: 20px; font-weight: 500; margin-bottom: 28px; }
.timeline-list {
  position: relative;
  padding-left: 80px;
}
.timeline-list::before {
  content: '';
  position: absolute;
  left: 44px;
  top: 6px;
  bottom: 6px;
  width: 1px;
  background: #E8E7E2;
}
.tl-item {
  position: relative;
  padding-bottom: 28px;
}
.tl-item:last-child { padding-bottom: 0; }
.tl-year {
  position: absolute;
  left: -76px;
  top: 2px;
  font-size: 12px;
  font-weight: 500;
  color: var(--c-teal);
  font-family: var(--font-mono);
  width: 48px;
  text-align: right;
}
.tl-dot {
  position: absolute;
  left: -40px;
  top: 6px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--c-teal);
  border: 2px solid var(--c-surface);
}
.tl-body { font-size: 14px; color: var(--c-ink); line-height: 1.65; }

@media (max-width: 768px) {
  .about-grid { grid-template-columns: 1fr; gap: 48px; }
  .page-title { flex-direction: column; gap: 4px; }
}
</style>
